{
  "name": "@langfuse/ee",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./sso": {
      "import": "./dist/src/sso/index.js",
      "require": "./dist/src/sso/index.js"
    }
  },
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "tsc",
    "build:check": "tsc",
    "typecheck": "dotenv -e ../../.env -- tsgo --noEmit --skipLibCheck --incremental --tsBuildInfoFile .tsbuildinfo",
    "dev": "tsc --watch",
    "lint": "oxlint . --deny-warnings && prettier --check \"**/*.{js,jsx,ts,tsx,cjs,mjs,mts,cts}\"",
    "lint:fix": "oxlint . --deny-warnings --fix && prettier --write \"**/*.{js,jsx,ts,tsx,cjs,mjs,mts,cts}\""
  },
  "dependencies": {
    "@langfuse/shared": "workspace:*",
    "@opentelemetry/api": ">=1.0.0 <1.10.0",
    "https-proxy-agent": "^7.0.6",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260122.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsc-watch": "^6.2.0",
    "typescript": "^5.7.2"
  }
}
